#
# Base image: pinned upstream vLLM. The test model weights are NOT baked in — the sanity
# script prefetches them at runtime (via huggingface_hub, which ships in the vLLM image)
# to keep this image small and its pull onto the GPU node fast. NIXL is intentionally NOT
# installed here either; the per-PR build (Dockerfile.vllm) layers the freshly-built PR
# wheels on top of this image.
# BASE_IMAGE is pinned to a concrete version so the per-PR sanity gate is reproducible;
# bump it (and CI_IMAGE_TAG) deliberately to move to a newer vLLM.
ARG BASE_IMAGE=docker.io/vllm/vllm-openai:v0.23.0
FROM --platform=$TARGETPLATFORM ${BASE_IMAGE}

ARG MODEL_ID=Qwen/Qwen3-8B

ENV NIXL_SANITY_MODEL_ID=${MODEL_ID}

# iproute2 provides `ss`, used by the sanity's get_next_tcp_port helper to skip occupied
# host ports (concurrent jobs share a SLURM node under host networking).
RUN apt-get update \
 && apt-get install -y --no-install-recommends iproute2 \
 && rm -rf /var/lib/apt/lists/*
